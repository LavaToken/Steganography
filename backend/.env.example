DATABASE_URL=postgresql://user:password@localhost:5432/stego_db
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
NODE_ENV=development
PORT=3001
# Comma-separated allowed origins in production (e.g. https://my-app.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Anthropic Claude API (for LLM image analysis feature)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Cloudinary (for encoded image storage — get from cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
